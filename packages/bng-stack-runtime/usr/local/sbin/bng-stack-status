#!/bin/bash
# bng-stack-status — show status of all BNG stack services

SETUP_CONF=/etc/bng-stack/setup.conf
GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[1;33m'
BOLD='\033[1m'; NC='\033[0m'

BR_COUNT=3
[ -f "$SETUP_CONF" ] && source "$SETUP_CONF" 2>/dev/null || true

svc_status() {
    local name="$1"
    local state
    state=$(systemctl is-active "$name" 2>/dev/null || echo "inactive")
    if [ "$state" = "active" ]; then
        echo -e "  ${GREEN}●${NC} ${name}: ${GREEN}active${NC}"
    else
        echo -e "  ${RED}●${NC} ${name}: ${RED}${state}${NC}"
    fi
}

echo ""
echo -e "${BOLD}BNG Stack Service Status${NC}"
echo "────────────────────────────────────"
svc_status vpp.service
svc_status frr.service
svc_status pppoe-neigh-sync.service
for i in $(seq 1 "$BR_COUNT"); do
    eval "bname=\${BR_NAME_${i}:-br${i}}"
    svc_status "accel-ppp@${bname}.service"
done
svc_status bng-monitor.service
svc_status vpp-exporter.service
echo "────────────────────────────────────"
echo ""

# Active PPPoE sessions per BR
if command -v accel-cmd >/dev/null 2>&1; then
    echo -e "${BOLD}Active Sessions${NC}"
    for i in $(seq 1 "$BR_COUNT"); do
        eval "bname=\${BR_NAME_${i}:-br${i}}"
        eval "bcli=\${BR_CLI_${i}:-$((2000+i*100+1))}"
        count=$(accel-cmd -p "$bcli" show stat 2>/dev/null | awk '/^active sessions/{print $NF}' || echo "?")
        echo "  ${bname}: ${count} sessions"
    done
    echo ""
fi

MONITOR_PORT="${MONITOR_PORT:-8877}"
echo -e "  Dashboard: http://$(hostname -I | awk '{print $1}'):${MONITOR_PORT}"
echo ""
