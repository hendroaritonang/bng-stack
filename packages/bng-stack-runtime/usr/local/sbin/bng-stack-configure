#!/bin/bash
# bng-stack-configure — interactive setup wizard for BNG Stack
# Usage: bng-stack-configure [--non-interactive --config /etc/bng-stack/setup.conf]

set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

TMPL_DIR=/etc/bng-stack/templates
SETUP_CONF=/etc/bng-stack/setup.conf
NON_INTERACTIVE=0

die()  { echo -e "${RED}ERROR: $*${NC}" >&2; exit 1; }
info() { echo -e "${CYAN}  → $*${NC}"; }
ok()   { echo -e "${GREEN}  ✓ $*${NC}"; }
warn() { echo -e "${YELLOW}  ⚠ $*${NC}"; }

ask() {
    local prompt="$1" default="$2" var="$3"
    if [ "$NON_INTERACTIVE" = "1" ]; then
        eval "$var=\"${default}\""
        return
    fi
    echo -ne "${BOLD}${prompt}${NC} [${default}]: "
    read -r input
    eval "$var=\"${input:-$default}\""
}

ask_required() {
    local prompt="$1" var="$2"
    while true; do
        echo -ne "${BOLD}${prompt}${NC}: "
        read -r input
        if [ -n "$input" ]; then
            eval "$var=\"$input\""
            return
        fi
        warn "This field is required."
    done
}

banner() {
    echo ""
    echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}${CYAN}║        BNG Stack Configuration Wizard    ║${NC}"
    echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════╝${NC}"
    echo ""
}

# ── parse args ────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
    case "$1" in
        --non-interactive) NON_INTERACTIVE=1 ;;
        --config) SETUP_CONF="$2"; shift ;;
    esac
    shift
done

# load existing answers if re-running
if [ -f "$SETUP_CONF" ] && [ "$NON_INTERACTIVE" = "1" ]; then
    # shellcheck source=/dev/null
    source "$SETUP_CONF"
fi

banner

# ════════════════════════════════════════════════════════════════
# SECTION 1: Network interfaces
# ════════════════════════════════════════════════════════════════
echo -e "${BOLD}[1/5] Network Interfaces${NC}"
echo "    Available PCI devices (DPDK candidates):"
lspci | grep -iE 'ethernet|network' | sed 's/^/      /' 2>/dev/null || true
echo ""

ask "Uplink interface (PCI name, e.g. enp4s0f0np0)" "${UPLINK_IF:-enp4s0f0np0}" UPLINK_IF
ask "PPPoE subscriber interface (PCI name, e.g. enp4s0f2np2)" "${PPPOE_IF:-enp4s0f2np2}" PPPOE_IF
ask "VPP main core number" "${VPP_MAIN_CORE:-0}" VPP_MAIN_CORE
ask "VPP worker cores (e.g. 1-4)" "${VPP_WORKERS:-1-4}" VPP_WORKERS
ask "Number of hugepages (2MB each)" "${NR_HUGEPAGES:-1024}" NR_HUGEPAGES

echo ""
echo "    Detecting PCI addresses for $UPLINK_IF and $PPPOE_IF ..."
UPLINK_PCI=$(ls -la /sys/class/net/"$UPLINK_IF"/device 2>/dev/null | grep -oP '[0-9a-f]{4}:[0-9a-f]{2}:[0-9a-f]{2}\.[0-9a-f]' | head -1 || echo "")
PPPOE_PCI=$(ls -la /sys/class/net/"$PPPOE_IF"/device 2>/dev/null | grep -oP '[0-9a-f]{4}:[0-9a-f]{2}:[0-9a-f]{2}\.[0-9a-f]' | head -1 || echo "")

if [ -z "$UPLINK_PCI" ]; then
    ask "PCI address for uplink ($UPLINK_IF)" "${UPLINK_PCI_MANUAL:-0000:04:00.0}" UPLINK_PCI
fi
if [ -z "$PPPOE_PCI" ]; then
    ask "PCI address for PPPoE interface ($PPPOE_IF)" "${PPPOE_PCI_MANUAL:-0000:04:00.2}" PPPOE_PCI
fi

# Extra DPDK devices
EXTRA_DPDK_DEVS="${EXTRA_DPDK_DEVS:-}"
ask "Extra DPDK PCI devices (space-separated, leave empty if none)" "${EXTRA_DPDK_DEVS}" EXTRA_DPDK_DEVS

echo ""

# ════════════════════════════════════════════════════════════════
# SECTION 2: BR (Broadband Remote) instances
# ════════════════════════════════════════════════════════════════
echo -e "${BOLD}[2/5] BR Instances (PPPoE Concentrators)${NC}"
ask "How many BR instances?" "${BR_COUNT:-3}" BR_COUNT

BR_CONFIGS=()
declare -A BR_DATA

for i in $(seq 1 "$BR_COUNT"); do
    echo ""
    echo -e "  ${BOLD}BR${i} Configuration:${NC}"
    ask "  BR${i} name" "${BR_NAME[$i]:-br${i}}" "BR_NAME_${i}"
    ask "  BR${i} VLAN ID" "${BR_VLAN[$i]:-$((99+i))}" "BR_VLAN_${i}"
    ask "  BR${i} gateway IP (loop IP, e.g. 192.168.${i}00.1)" "${BR_GW[$i]:-192.168.$((99+i)).1}" "BR_GW_${i}"
    ask "  BR${i} NAS IP address (this router's IP for RADIUS)" "${NAS_IP:-$(hostname -I | awk '{print $1}')}" "BR_NAS_${i}"
    ask "  BR${i} CLI TCP port" "${BR_CLI[$i]:-$((2000+i*100+1))}" "BR_CLI_${i}"
    ask "  BR${i} CLI telnet port" "${BR_TELNET[$i]:-$((2000+i*100))}" "BR_TELNET_${i}"
done

echo ""

# ════════════════════════════════════════════════════════════════
# SECTION 3: RADIUS
# ════════════════════════════════════════════════════════════════
echo -e "${BOLD}[3/5] RADIUS Server${NC}"
ask_required "  RADIUS server IP" RADIUS_SERVER
ask_required "  RADIUS secret" RADIUS_SECRET
ask "  DNS1" "${DNS1:-8.8.8.8}" DNS1
ask "  DNS2" "${DNS2:-8.8.4.4}" DNS2

echo ""

# ════════════════════════════════════════════════════════════════
# SECTION 4: BNG Monitor
# ════════════════════════════════════════════════════════════════
echo -e "${BOLD}[4/5] BNG Monitor Web Dashboard${NC}"
ask "  Dashboard port" "${MONITOR_PORT:-8877}" MONITOR_PORT
ask "  Admin username" "${MONITOR_USER:-admin}" MONITOR_USER
ask "  Admin password" "${MONITOR_PASS:-admin}" MONITOR_PASS
ask "  JWT secret key (leave blank to auto-generate)" "" MONITOR_SECRET
if [ -z "$MONITOR_SECRET" ]; then
    MONITOR_SECRET=$(openssl rand -hex 32)
fi

echo ""

# ════════════════════════════════════════════════════════════════
# SECTION 5: Confirm and apply
# ════════════════════════════════════════════════════════════════
echo -e "${BOLD}[5/5] Summary${NC}"
echo ""
echo "  Uplink interface : $UPLINK_IF ($UPLINK_PCI)"
echo "  PPPoE interface  : $PPPOE_IF ($PPPOE_PCI)"
echo "  VPP cores        : main=$VPP_MAIN_CORE workers=$VPP_WORKERS"
echo "  Hugepages        : $NR_HUGEPAGES × 2MB"
echo "  BR instances     : $BR_COUNT"
for i in $(seq 1 "$BR_COUNT"); do
    eval "bname=\$BR_NAME_${i}"; eval "bvlan=\$BR_VLAN_${i}"; eval "bgw=\$BR_GW_${i}"
    echo "    BR${i}: $bname  vlan=$bvlan  gw=$bgw"
done
echo "  RADIUS           : $RADIUS_SERVER"
echo "  Monitor port     : $MONITOR_PORT"
echo ""

if [ "$NON_INTERACTIVE" != "1" ]; then
    echo -ne "${BOLD}Apply this configuration? [y/N]:${NC} "
    read -r confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 0; }
fi

# ════════════════════════════════════════════════════════════════
# APPLY CONFIGURATION
# ════════════════════════════════════════════════════════════════
echo ""
info "Saving setup to $SETUP_CONF ..."
mkdir -p "$(dirname "$SETUP_CONF")"
cat > "$SETUP_CONF" <<CONF
# bng-stack setup — generated by bng-stack-configure $(date)
UPLINK_IF="$UPLINK_IF"
UPLINK_PCI="$UPLINK_PCI"
PPPOE_IF="$PPPOE_IF"
PPPOE_PCI="$PPPOE_PCI"
EXTRA_DPDK_DEVS="$EXTRA_DPDK_DEVS"
VPP_MAIN_CORE="$VPP_MAIN_CORE"
VPP_WORKERS="$VPP_WORKERS"
NR_HUGEPAGES="$NR_HUGEPAGES"
BR_COUNT="$BR_COUNT"
RADIUS_SERVER="$RADIUS_SERVER"
RADIUS_SECRET="$RADIUS_SECRET"
DNS1="$DNS1"
DNS2="$DNS2"
MONITOR_PORT="$MONITOR_PORT"
MONITOR_USER="$MONITOR_USER"
MONITOR_PASS="$MONITOR_PASS"
MONITOR_SECRET="$MONITOR_SECRET"
CONF
for i in $(seq 1 "$BR_COUNT"); do
    eval "echo \"BR_NAME_${i}=\\\"\$BR_NAME_${i}\\\"\"" >> "$SETUP_CONF"
    eval "echo \"BR_VLAN_${i}=\\\"\$BR_VLAN_${i}\\\"\"" >> "$SETUP_CONF"
    eval "echo \"BR_GW_${i}=\\\"\$BR_GW_${i}\\\"\"" >> "$SETUP_CONF"
    eval "echo \"BR_NAS_${i}=\\\"\$BR_NAS_${i}\\\"\"" >> "$SETUP_CONF"
    eval "echo \"BR_CLI_${i}=\\\"\$BR_CLI_${i}\\\"\"" >> "$SETUP_CONF"
    eval "echo \"BR_TELNET_${i}=\\\"\$BR_TELNET_${i}\\\"\"" >> "$SETUP_CONF"
done

# ── hugepages sysctl ──────────────────────────────────────────
info "Applying hugepages (vm.nr_hugepages=$NR_HUGEPAGES) ..."
sed -i "s/^vm.nr_hugepages=.*/vm.nr_hugepages=${NR_HUGEPAGES}/" /etc/sysctl.d/90-bng-stack-vpp.conf
sysctl -p /etc/sysctl.d/90-bng-stack-vpp.conf >/dev/null

# ── build DPDK devices block ──────────────────────────────────
DPDK_BLOCK="  dev ${UPLINK_PCI} { name ${UPLINK_IF} }\n"
DPDK_BLOCK+="  dev ${PPPOE_PCI} { name ${PPPOE_IF} }"
for extra in $EXTRA_DPDK_DEVS; do
    DPDK_BLOCK+="\n  dev ${extra} { }"
done

# ── build BR blocks for bootstrap.cli ────────────────────────
BR_BOOTSTRAP=""
for i in $(seq 1 "$BR_COUNT"); do
    eval "bvlan=\$BR_VLAN_${i}"
    eval "bgw=\$BR_GW_${i}"
    eval "bname=\$BR_NAME_${i}"
    # derive loop instance from 3rd octet of GW IP
    LOOP_INST=$(echo "$bgw" | awk -F. '{print $3}')
    BR_BOOTSTRAP+="create sub-interface ${PPPOE_IF} ${bvlan}\n"
    BR_BOOTSTRAP+="set interface state ${PPPOE_IF}.${bvlan} up\n\n"
done
BR_BOOTSTRAP+="lcp lcp-sync on\nlcp lcp-auto-subint on\n\n"
# LCP create for uplink
UPLINK_IDX=4096
BR_BOOTSTRAP+="lcp create ${UPLINK_IF} host-if lcp-${UPLINK_IF} instance ${UPLINK_IDX}\n"
BR_BOOTSTRAP+="set interface state tap${UPLINK_IDX} up\n\n"
# LCP + pppoe-map per VLAN
LCP_INSTANCE=100
BR_BOOTSTRAP+="lcp create ${PPPOE_IF} host-if lcp-${PPPOE_IF} instance ${LCP_INSTANCE}\n"
for i in $(seq 1 "$BR_COUNT"); do
    eval "bvlan=\$BR_VLAN_${i}"
    eval "bgw=\$BR_GW_${i}"
    LOOP_INST=$(echo "$bgw" | awk -F. '{print $3}')
    BR_BOOTSTRAP+="lcp create ${PPPOE_IF}.${bvlan} host-if vlan${bvlan}\n"
    BR_BOOTSTRAP+="set interface state tap${LCP_INSTANCE}.${bvlan} up\n"
done
BR_BOOTSTRAP+="\n"
for i in $(seq 1 "$BR_COUNT"); do
    eval "bvlan=\$BR_VLAN_${i}"
    BR_BOOTSTRAP+="create pppoe map dp ${PPPOE_IF}.${bvlan} cp tap${LCP_INSTANCE}.${bvlan}\n"
done
BR_BOOTSTRAP+="\n"
for i in $(seq 1 "$BR_COUNT"); do
    eval "bgw=\$BR_GW_${i}"
    LOOP_INST=$(echo "$bgw" | awk -F. '{print $3}')
    GW_CIDR="${bgw%.*}.0/24"
    BR_BOOTSTRAP+="create loopback interface instance ${LOOP_INST}\n"
    BR_BOOTSTRAP+="set interface state loop${LOOP_INST} up\n"
    BR_BOOTSTRAP+="set interface ip address loop${LOOP_INST} ${bgw}/24\n\n"
done

# ── write VPP startup.conf ────────────────────────────────────
info "Writing /etc/vpp/startup.conf ..."
cp "$TMPL_DIR/vpp-startup.conf.tmpl" /tmp/vpp-startup.conf.new
sed -i "s/{{VPP_MAIN_CORE}}/$VPP_MAIN_CORE/" /tmp/vpp-startup.conf.new
sed -i "s/{{VPP_WORKERS}}/$VPP_WORKERS/" /tmp/vpp-startup.conf.new
# Multi-line replacement for DPDK block
python3 -c "
import re, sys
content = open('/tmp/vpp-startup.conf.new').read()
content = content.replace('{{DPDK_DEVICES}}', '''${DPDK_BLOCK}''')
open('/tmp/vpp-startup.conf.new', 'w').write(content)
"
cp /tmp/vpp-startup.conf.new /etc/vpp/startup.conf
ok "Written /etc/vpp/startup.conf"

# ── write VPP bootstrap.cli ───────────────────────────────────
info "Writing /etc/vpp/bootstrap.cli ..."
python3 -c "
import sys
tmpl = open('${TMPL_DIR}/vpp-bootstrap.cli.tmpl').read()
tmpl = tmpl.replace('{{UPLINK_IF}}', '${UPLINK_IF}')
tmpl = tmpl.replace('{{PPPOE_IF}}', '${PPPOE_IF}')
tmpl = tmpl.replace('{{BR_BLOCKS}}', '${BR_BOOTSTRAP}'.replace('\\\\n', '\n'))
open('/etc/vpp/bootstrap.cli', 'w').write(tmpl)
"
ok "Written /etc/vpp/bootstrap.cli"

# ── write accel-ppp configs ───────────────────────────────────
info "Writing accel-ppp instance configs ..."
for i in $(seq 1 "$BR_COUNT"); do
    eval "bname=\$BR_NAME_${i}"
    eval "bvlan=\$BR_VLAN_${i}"
    eval "bgw=\$BR_GW_${i}"
    eval "bnas=\$BR_NAS_${i}"
    eval "bcli=\$BR_CLI_${i}"
    eval "btelnet=\$BR_TELNET_${i}"

    sed \
        -e "s|{{BR_NAME}}|${bname}|g" \
        -e "s|{{VLAN_ID}}|${bvlan}|g" \
        -e "s|{{AC_NAME}}|accel-vpp-ng-${bname}|g" \
        -e "s|{{GW_IP}}|${bgw}|g" \
        -e "s|{{NAS_IP}}|${bnas}|g" \
        -e "s|{{RADIUS_SERVER}}|${RADIUS_SERVER}|g" \
        -e "s|{{RADIUS_SECRET}}|${RADIUS_SECRET}|g" \
        -e "s|{{CLI_PORT}}|${bcli}|g" \
        -e "s|{{CLI_TELNET}}|${btelnet}|g" \
        -e "s|{{DNS1}}|${DNS1}|g" \
        -e "s|{{DNS2}}|${DNS2}|g" \
        -e "s|{{THREAD_COUNT}}|${VPP_WORKERS##*-}|g" \
        "$TMPL_DIR/accel-ppp-br.conf.tmpl" \
        > "/etc/accel-ppp-${bname}.conf"

    # enable accel-ppp systemd instance
    systemctl enable "accel-ppp@${bname}.service" 2>/dev/null || true
    ok "Written /etc/accel-ppp-${bname}.conf"
done

# ── write bng-monitor env ─────────────────────────────────────
info "Configuring bng-monitor ..."
mkdir -p /etc/bng-stack
cat > /etc/bng-stack/monitor.env <<ENV
BNG_MONITOR_DATA=/var/lib/bng-monitor
BNG_MONITOR_SECRET=${MONITOR_SECRET}
BNG_MONITOR_PORT=${MONITOR_PORT}
BNG_MONITOR_ADMIN_USER=${MONITOR_USER}
BNG_MONITOR_ADMIN_PASS=${MONITOR_PASS}
ENV
ok "Written /etc/bng-stack/monitor.env"

# update bng-monitor.service port if non-default
if [ "$MONITOR_PORT" != "8877" ]; then
    sed -i "s/--port [0-9]*/--port ${MONITOR_PORT}/" /etc/systemd/system/bng-monitor.service 2>/dev/null || true
fi
systemctl daemon-reload

# ── create log dir ────────────────────────────────────────────
mkdir -p /var/log/accel-ppp /var/lib/bng-monitor /run/accel-ppp-vpp

echo ""
echo -e "${GREEN}${BOLD}Configuration complete!${NC}"
echo ""
echo "  Next steps:"
echo "    1. Review /etc/vpp/startup.conf  and /etc/vpp/bootstrap.cli"
echo "    2. Run: bng-stack-start          to start all services"
echo "    3. Open: http://$(hostname -I | awk '{print $1}'):${MONITOR_PORT}"
echo ""
